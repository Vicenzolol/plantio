# Conexão com o Neon Postgres.
# Local: use a connection string da branch de DESENVOLVIMENTO.
# Produção (Vercel): configure a string da branch de PRODUÇÃO no painel da Vercel.
DATABASE_URL="postgresql://user:password@ep-xxxx.region.aws.neon.tech/plantio?sslmode=require"

# Segredo para assinar os JWT de sessão. Gere um valor longo e aleatório.
# Ex (PowerShell):  [Convert]::ToBase64String((1..48 | %{ Get-Random -Max 256 }))
JWT_SECRET="troque-por-um-segredo-longo-e-aleatorio"
